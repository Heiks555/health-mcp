# --- MCP tools (Open Wearables) ---
HEALTH_PROVIDER=openwearables
OW_API_KEY=
# Optional, defaults to the production Railway OW backend:
# OW_BASE_URL=https://backend-production-21d7.up.railway.app

# --- Claude API proxy (for the Suund app's /api/analyze and /api/chat) ---
# Server-side only. Never expose this to the app bundle.
ANTHROPIC_API_KEY=

# Shared secret the Suund app sends as the X-Suund-App-Key header. Not real auth —
# just stops random traffic from reaching the Claude-backed endpoints. Generate any
# long random string, e.g.: openssl rand -hex 32
SUUND_APP_KEY=

# --- Misc ---
# PORT=3000
